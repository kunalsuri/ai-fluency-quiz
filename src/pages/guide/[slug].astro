import Base from '../../layouts/Base.astro';
import GuideTopic from '../../components/GuideTopic.astro';
import { getGuideTopics } from '../../lib/data';
import { tr } from '../../lib/i18n';

export function getStaticPaths() {
  return getGuideTopics('en').map((topic) => ({
    params: { slug: topic.slug },
    props: { topic },
  }));
}

const { topic } = Astro.props;
---

<Base lang="en" title={`${topic.topic} · ${tr('en', 'guideTitle')}`} description={topic.description}>
  <GuideTopic lang="en" topic={topic} />
</Base>
